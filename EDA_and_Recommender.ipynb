    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import plotly.express as px\n",
    "import plotly.graph_objects as go\n",
    "from sklearn.metrics.pairwise import cosine_similarity\n",
    "from IPython.display import display, HTML\n",
    "\n",
    "plt.rcParams['figure.facecolor'] = '#0d0d1a'\n",
    "plt.rcParams['axes.facecolor'] = '#1a1a2e'\n",
    "plt.rcParams['text.color'] = '#e8e8f0'\n",
    "plt.rcParams['axes.labelcolor'] = '#c77dff'\n",
    "plt.rcParams['xtick.color'] = '#e8e8f0'\n",
    "plt.rcParams['ytick.color'] = '#e8e8f0'\n",
    "plt.rcParams['axes.titlecolor'] = '#c77dff'\n",
    "\n",
    "df = pd.read_csv('animes.csv')\n",
    "GENRE_COLS = [c for c in df.columns if c.startswith('genre_')]\n",
    "GENRE_LABELS = [c.replace('genre_', '').replace('-', ' ').title() for c in GENRE_COLS]\n",
    "print(f'Dataset shape: {df.shape}')\n",
    "df.head(3)"
   ]
